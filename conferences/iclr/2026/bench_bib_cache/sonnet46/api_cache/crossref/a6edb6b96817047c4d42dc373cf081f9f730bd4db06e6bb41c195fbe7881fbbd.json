[{"publisher": "Springer Science and Business Media LLC", "DOI": "10.1007/s10858-007-9192-4", "type": "journal-article", "title": ["Hadamard NMR spectroscopy for relaxation measurements of large (&gt;35 kDa) proteins"], "author": [{"given": "B. Tom", "family": "Burnley", "sequence": "first", "affiliation": []}, {"given": "Arnout P.", "family": "Kalverda", "sequence": "additional", "affiliation": []}, {"given": "Stephen J.", "family": "Paisey", "sequence": "additional", "affiliation": []}, {"given": "Alan", "family": "Berry", "sequence": "additional", "affiliation": []}, {"given": "Steve W.", "family": "Homans", "sequence": "additional", "affiliation": []}], "container-title": ["Journal of Biomolecular NMR"], "link": [{"URL": "http://link.springer.com/content/pdf/10.1007/s10858-007-9192-4.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "http://link.springer.com/article/10.1007/s10858-007-9192-4/fulltext.html", "content-type": "text/html", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "http://link.springer.com/content/pdf/10.1007/s10858-007-9192-4", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1007/s10858-007-9192-4", "published": {"date-parts": [[2007, 9, 20]]}}, {"publisher": "Springer Science and Business Media LLC", "DOI": "10.1007/s10858-007-9186-2", "type": "journal-article", "title": ["Complexity of aromatic ring-flip motions in proteins: Y97 ring dynamics in cytochrome c observed by cross-relaxation suppressed exchange NMR spectroscopy"], "author": [{"given": "D.", "family": "Krishna Rao", "sequence": "first", "affiliation": []}, {"given": "Abani K.", "family": "Bhuyan", "sequence": "additional", "affiliation": []}], "container-title": ["Journal of Biomolecular NMR"], "link": [{"URL": "http://link.springer.com/content/pdf/10.1007/s10858-007-9186-2.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "http://link.springer.com/article/10.1007/s10858-007-9186-2/fulltext.html", "content-type": "text/html", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "http://link.springer.com/content/pdf/10.1007/s10858-007-9186-2", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1007/s10858-007-9186-2", "published": {"date-parts": [[2007, 9, 11]]}}, {"publisher": "Wiley", "abstract": "<jats:title>Abstract</jats:title>\n                  <jats:p>\n                    Molecular dynamics (MD) simulations and nuclear magnetic resonance spin‐relaxation measurements provide detailed insights into ps‐ns structural dynamics of proteins. An analysis of discrepancies between the two methods is presented for the B3 immunoglobulin‐binding domain of streptococcal protein G. MD simulations using three MD force fields (OPLS‐AA, AMBER ff99SB, and AMBER ff03) overestimate the flexibility of backbone NH vectors at the borders of secondary structure and in loops when compared with experimentally determined backbone amide generalized order parameters (Hall and Fushman,\n                    <jats:ext-link xmlns:xlink=\"http://www.w3.org/1999/xlink\" xlink:href=\"#bib7\">J Am Chem Soc 2006; 12:7855–7870</jats:ext-link>\n                    ). Comparison with a previous study of residual dipolar coupling constants (Bouvignies\n                    <jats:italic>et al.</jats:italic>\n                    ,\n                    <jats:ext-link xmlns:xlink=\"http://www.w3.org/1999/xlink\" xlink:href=\"#bib8\">Proc Natl Acad Sci USA 2005;102:13885–13890</jats:ext-link>\n                    ) indicates that slower timescale motions do not account for the discrepancies. Structural analysis reveals that relative imbalance between the description of hydrogen bonding and other terms of modern force fields may be responsible for disagreement. Proteins 2008. © 2007 Wiley‐Liss, Inc.\n                  </jats:p>", "DOI": "10.1002/prot.21750", "type": "journal-article", "title": ["Structural analysis of protein dynamics by MD simulations and NMR spin‐relaxation"], "author": [{"given": "Nikola", "family": "Trbovic", "sequence": "first", "affiliation": []}, {"given": "Byungchan", "family": "Kim", "sequence": "additional", "affiliation": []}, {"given": "Richard A.", "family": "Friesner", "sequence": "additional", "affiliation": []}, {"suffix": "III", "given": "Arthur G.", "family": "Palmer", "sequence": "additional", "affiliation": []}], "container-title": ["Proteins: Structure, Function, and Bioinformatics"], "link": [{"URL": "https://api.wiley.com/onlinelibrary/tdm/v1/articles/10.1002%2Fprot.21750", "content-type": "unspecified", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://onlinelibrary.wiley.com/doi/pdf/10.1002/prot.21750", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1002/prot.21750", "published": {"date-parts": [[2007, 11]]}}, {"publisher": "Springer Science and Business Media LLC", "DOI": "10.1007/s10858-007-9152-z", "type": "journal-article", "title": ["1-13C amino acid selective labeling in a 2H15N background for NMR studies of large proteins"], "author": [{"given": "Koh", "family": "Takeuchi", "sequence": "first", "affiliation": []}, {"given": "Elise", "family": "Ng", "sequence": "additional", "affiliation": []}, {"given": "Thomas J.", "family": "Malia", "sequence": "additional", "affiliation": []}, {"given": "Gerhard", "family": "Wagner", "sequence": "additional", "affiliation": []}], "container-title": ["Journal of Biomolecular NMR"], "link": [{"URL": "https://link.springer.com/content/pdf/10.1007/s10858-007-9152-z.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "https://link.springer.com/article/10.1007/s10858-007-9152-z/fulltext.html", "content-type": "text/html", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "http://link.springer.com/content/pdf/10.1007/s10858-007-9152-z", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}, {"URL": "https://link.springer.com/content/pdf/10.1007/s10858-007-9152-z.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1007/s10858-007-9152-z", "published": {"date-parts": [[2007, 3, 28]]}}, {"publisher": "Springer Science and Business Media LLC", "DOI": "10.1007/s10858-007-9171-9", "type": "journal-article", "title": ["Model-free analysis for large proteins at high magnetic field strengths"], "author": [{"given": "Shou-Lin", "family": "Chang", "sequence": "first", "affiliation": []}, {"given": "Andrew P.", "family": "Hinck", "sequence": "additional", "affiliation": []}, {"given": "Rieko", "family": "Ishima", "sequence": "additional", "affiliation": []}], "container-title": ["Journal of Biomolecular NMR"], "link": [{"URL": "http://link.springer.com/content/pdf/10.1007/s10858-007-9171-9.pdf", "content-type": "application/pdf", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "http://link.springer.com/article/10.1007/s10858-007-9171-9/fulltext.html", "content-type": "text/html", "content-version": "vor", "intended-application": "text-mining"}, {"URL": "http://link.springer.com/content/pdf/10.1007/s10858-007-9171-9", "content-type": "unspecified", "content-version": "vor", "intended-application": "similarity-checking"}], "URL": "https://doi.org/10.1007/s10858-007-9171-9", "published": {"date-parts": [[2007, 6, 26]]}}]